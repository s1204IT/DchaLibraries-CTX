<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/normal_default_account_select_title_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/account_select_notification_img"
                android:background="@drawable/notification_icon_legacy_bg"
                android:padding="9dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/account_select_notification"/>
        </FrameLayout>
        <TextView
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:textColor="#000000"
            android:layout_gravity="center_vertical"
            android:id="@+id/default_account_select_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/Default_Account_Selection_Content"
            android:paddingStart="10dp"/>
    </LinearLayout>
</FrameLayout>
