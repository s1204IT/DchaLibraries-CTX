<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/media_controller"
    android:layout_width="match_parent"
    android:layout_height="76dp">
    <ImageView
        android:id="@+id/media_controller_background"
        android:background="@drawable/mtk_ic_video_widget_panel"
        android:layout_width="match_parent"
        android:layout_height="46dp"/>
    <android.widget.video.MTKWidgetSeekBar
        android:id="@+id/video_progress"
        android:saveEnabled="false"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:maxHeight="2dp"
        android:indeterminate="false"
        android:indeterminateDrawable="@drawable/mtk_ic_video_widget_seekbar_background"
        android:minHeight="2dp"
        android:thumb="@drawable/mtk_ic_video_widget_indicator"
        android:thumbOffset="0dp"
        style="?android:attr/progressBarStyleHorizontal"/>
    <ImageView
        android:id="@+id/video_fullscreen"
        android:paddingLeft="6dp"
        android:paddingTop="1dp"
        android:paddingRight="6dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginLeft="4dp"
        android:src="@drawable/mtk_video_widget_button_fullscreen"
        android:layout_below="@+id/video_progress"
        android:layout_alignParentLeft="true"/>
    <ImageView
        android:id="@+id/video_replay"
        android:paddingLeft="6dp"
        android:paddingTop="1dp"
        android:paddingRight="6dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginLeft="20dp"
        android:src="@drawable/mtk_video_widget_button_replay"
        android:layout_toRightOf="@+id/video_fullscreen"
        android:layout_below="@+id/video_progress"/>
    <ImageView
        android:id="@+id/video_pause"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/mtk_ic_video_widget_start_icon"
        android:layout_below="@+id/video_progress"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:id="@+id/video_pick"
        android:paddingLeft="6dp"
        android:paddingTop="1dp"
        android:paddingRight="6dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginRight="4dp"
        android:src="@drawable/mtk_video_widget_button_pick"
        android:layout_below="@+id/video_progress"
        android:layout_alignParentRight="true"/>
</RelativeLayout>
